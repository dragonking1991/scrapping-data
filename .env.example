GDT_CHECKPOINT_PATH=.checkpoint.json
GDT_RESUME_ON_RELOGIN=true
GDT_INVOICE_TYPE=invoice
GDT_EXPORT_ENDPOINTS=/api/query/invoices/user-third-party/export-excel-sold,/api/query/invoices/user-third-party/export-xml-sold
