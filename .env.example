GDT_BASE_URL=https://hoadondientu.gdt.gov.vn
GDT_USERNAME=
GDT_PASSWORD=
GDT_ENDPOINT_PROFILE=third-party
GDT_SOLD_ENDPOINT=/api/query/invoices/user-third-party/sold
GDT_DETAIL_ENDPOINT=/api/query/invoices/user-third-party/detail-sold
GDT_CAPTCHA_MODE=auto
GDT_CAPTCHA_MAX_ATTEMPTS=8
GDT_TOKEN_CACHE_PATH=.token.json
GDT_REQUEST_DELAY_MS=200
